{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": [
    "node_modules",
    "app/recipes/**/*",
    "app/inventory/**/*",
    "app/shopping-list/**/*",
    "utils/supabase/**/*",
    "app/api/analyze-receipt/**/*",
    "app/api/generate-recipe/**/*",
    "app/api/parse-recipe-image/**/*",
    "app/api/parse-recipe-text/**/*",
    "app/api/update-preferences/**/*"
  ]
}
