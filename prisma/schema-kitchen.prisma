// AI Kitchen Partner Database Schema
// This schema is designed for Supabase PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Inventory {
  id          String   @id @default(uuid())
  user_id     String
  name        String
  quantity    String
  expiry_date DateTime?
  category    String
  created_at  DateTime @default(now())

  @@index([user_id])
  @@map("inventory")
}

model Recipe {
  id          String   @id @default(uuid())
  user_id     String
  title       String
  description String?
  ingredients Json     // [{ name: string, quantity: string }]
  steps       Json     // [string]
  calories    String?
  image_url   String?
  source_type String   // 'manual', 'url_import', 'ocr_import', 'ai_generated'
  is_favorite Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([user_id])
  @@map("recipes")
}

model RecipeHistory {
  id                  String   @id @default(uuid())
  user_id             String
  generated_recipe_json Json
  rating              Int?     // 1-5
  feedback_text       String?
  created_at          DateTime @default(now())

  @@index([user_id])
  @@map("recipe_history")
}

model ShoppingList {
  id        String   @id @default(uuid())
  user_id   String
  item_name String
  is_checked Boolean @default(false)
  created_at DateTime @default(now())

  @@index([user_id])
  @@map("shopping_list")
}

model UserPreferences {
  user_id            String   @id
  preferences_summary String?
  updated_at         DateTime @updatedAt

  @@map("user_preferences")
}







