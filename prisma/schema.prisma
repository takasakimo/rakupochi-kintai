// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 企業テーブル
model Company {
  id          Int       @id @default(autoincrement())
  name        String
  code        String    @unique // 企業コード
  email       String?
  phone       String?
  address     String?
  // 請求書関連フィールド
  issuerName  String?   // 発行者名（請求書に表示）
  taxId       String?   // 適格番号
  bankName    String?   // 振込先銀行名
  bankBranch  String?   // 振込先支店名
  accountNumber String? // 振込先口座番号
  accountHolder String? // 振込先口座名義
  invoiceItemNameTemplate String? // 請求書費目テンプレート（{employeeName}で従業員名を埋め込み可能）
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  employees   Employee[]
  locations   Location[]
  shifts      Shift[]
  applications Application[]
  attendances Attendance[]
  settings    CompanySetting?
  announcements Announcement[]
  attendanceModificationLogs AttendanceModificationLog[]
  salesVisits SalesVisit[]
  billingClients BillingClient[]
  invoices Invoice[]

  @@map("companies")
}

// 従業員テーブル
model Employee {
  id          Int       @id @default(autoincrement())
  companyId   Int
  employeeNumber String  // 社員番号（企業ごとにユニーク）
  name        String
  email       String    @unique
  password    String    // ハッシュ化されたパスワード
  role        String    @default("employee") // employee, admin
  department  String?
  workLocation String?  // 店舗・事業所
  workLocationAddress String?  // 勤務先住所
  position    String?
  phone       String?
  birthDate   DateTime? @db.Date // 生年月日
  address     String?   // 住所
  hireDate    DateTime?
  bankAccount String?   // 振込先口座
  transportationRoutes Json?     // 交通経路 [{from, to, method, amount}]
  transportationCost   Int?      // 交通費（月額、円）
  paidLeaveGrantDate DateTime?  @db.Date // 有給付与日
  yearsOfService      Float?              // 勤続年数（手動設定可能）
  paidLeaveBalance    Int       @default(0) // 有給残数
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  attendances Attendance[]
  applications Application[]
  shifts      Shift[]
  notifications Notification[]
  passwordResetTokens PasswordResetToken[]
  attendanceModificationLogs AttendanceModificationLog[] @relation("Modifier")
  salesVisits SalesVisit[]
  invoiceDetails InvoiceDetail[]

  // 請求関連フィールド
  billingClientId Int?      // 請求先企業ID
  billingRate     Int?      // 請求単価
  billingRateType String?  @default("daily") // 請求単価タイプ: "hourly"（時給）, "daily"（日給）, "monthly"（月給）
  overtimeRate    Float?    @default(1.25) // 残業単価倍率
  hasOvertime     Boolean   @default(false) // 残業の有無
  baseWorkDays    Int?      @default(22) // 稼働日数のベース（月間）
  invoiceItemName String?   // 請求書費目（設定がない場合はテンプレートを使用）
  businessName    String?   // 業務名（費目名の「〇〇委託費用」の「〇〇」部分）

  billingClient   BillingClient? @relation(fields: [billingClientId], references: [id])

  @@unique([companyId, employeeNumber]) // 企業ごとに社員番号をユニークに
  @@map("employees")
}

// 店舗・事業所の位置情報
model Location {
  id          Int       @id @default(autoincrement())
  companyId   Int
  name        String    // 店舗名・事業所名
  type        String    @default("store") // "store" (店舗) または "department" (部署)
  address     String?
  latitude    Float     // 緯度
  longitude   Float     // 経度
  radius      Int       @default(500) // 許容範囲（メートル）
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("locations")
}

// 勤怠テーブル（4段階打刻）
model Attendance {
  id                Int       @id @default(autoincrement())
  companyId         Int
  employeeId        Int
  date              DateTime  @db.Date

  // 4段階打刻
  wakeUpTime        DateTime? @db.Time // 起床時刻
  departureTime     DateTime? @db.Time // 出発時刻
  clockIn           DateTime? @db.Time // 出勤時刻
  clockOut          DateTime? @db.Time // 退勤時刻

  // GPS位置情報（出勤・退勤時のみ）
  clockInLocation   Json?     // {latitude, longitude, accuracy, locationName, distance}
  clockOutLocation  Json?     // {latitude, longitude, accuracy, locationName, distance}

  // その他
  breakMinutes      Int       @default(0)
  notes             String?
  isDeleted         Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee          Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  modificationLogs  AttendanceModificationLog[]

  @@unique([companyId, employeeId, date])
  @@map("attendances")
}

// シフトテーブル
model Shift {
  id          Int       @id @default(autoincrement())
  companyId   Int
  employeeId  Int
  date        DateTime  @db.Date
  startTime   DateTime? @db.Time
  endTime     DateTime? @db.Time
  breakMinutes Int      @default(0)
  notes       String?
  status      String    @default("confirmed") // confirmed, requested, exchanged
  
  // 追加フィールド（PDF要件に基づく）
  isPublicHoliday Boolean @default(false) // 公休フラグ
  workLocation    String? // 勤務場所
  workType        String? // 勤務種別（出勤、公休など）
  workingHours    String? // 勤務時間（例: "8:00"）
  timeSlot        String? // 時間帯選択
  directDestination String? // 直行先
  approvalNumber  String? // 稟議番号
  leavingLocation String? // 退勤場所
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("shifts")
}

// 申請テーブル（打刻修正、残業、休暇、経費等）
model Application {
  id          Int       @id @default(autoincrement())
  companyId   Int
  employeeId  Int
  type        String    // attendance_correction, overtime, leave, expense, shift_exchange, shift_request
  status      String    @default("pending") // pending, approved, rejected
  title       String?
  content     String    // 申請内容（JSON形式で種別ごとに異なる）
  reason      String?   // 理由（打刻修正時は必須）
  approverId  Int?      // 承認者ID
  approvedAt  DateTime?
  rejectedAt  DateTime?
  rejectionReason String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("applications")
}

// 通知・アラートテーブル
model Notification {
  id          Int       @id @default(autoincrement())
  employeeId  Int
  type        String    // overtime_alert, attendance_missing, leave_expiry, consecutive_work
  title       String
  message     String
  isRead      Boolean   @default(false)
  createdAt   DateTime  @default(now())

  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

// 企業設定テーブル
model CompanySetting {
  id                Int       @id @default(autoincrement())
  companyId         Int       @unique
  payday            Int       @default(25) // 給与締め日
  workStartTime     DateTime? @db.Time // 標準始業時刻
  workEndTime       DateTime? @db.Time // 標準終業時刻
  standardBreakMinutes Int    @default(60) // 標準休憩時間（分）
  overtimeThreshold40 Int     @default(40) // 残業40時間アラート
  overtimeThreshold60 Int     @default(60) // 残業60時間アラート
  consecutiveWorkAlert Int     @default(6) // 連続勤務アラート（日数）
  leaveExpiryAlertDays Int     @default(30) // 有給失効前通知（日数）
  allowPreOvertime     Boolean @default(false) // 前残業を認めるかどうか
  enableSalesVisit      Boolean @default(true) // 営業先入退店機能を有効にするかどうか
  enableWakeUpDeparture Boolean @default(true) // 起床・出発報告機能を有効にするかどうか
  enableInvoice         Boolean @default(false) // 請求書作成機能を有効にするかどうか
  // 有給付与設定
  paidLeaveFirstGrantMonths Int @default(6) // 初回有給付与までの月数（例：6ヶ月）
  paidLeaveGrantDays Json? // 年次ごとの付与日数 {year1: 10, year2: 11, year3: 12, year4: 14, year5: 16, year6: 18, year7: 20}
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_settings")
}

// お知らせテーブル
model Announcement {
  id          Int       @id @default(autoincrement())
  companyId   Int
  title       String    // タイトル
  content     String    // 本文（コメント）
  attachments Json?     // 添付ファイル [{name, type, data}] (Base64エンコード)
  isActive    Boolean   @default(true) // 公開中かどうか
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("announcements")
}

// パスワードリセットトークンテーブル
model PasswordResetToken {
  id        Int       @id @default(autoincrement())
  employeeId Int
  token     String    @unique // リセットトークン
  expiresAt DateTime  // 有効期限
  used      Boolean   @default(false) // 使用済みフラグ
  createdAt DateTime  @default(now())

  employee  Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

// 打刻修正履歴テーブル
model AttendanceModificationLog {
  id                Int       @id @default(autoincrement())
  attendanceId      Int
  companyId         Int
  employeeId        Int
  modifiedBy        Int       // 修正を行った管理者のID
  action            String    // "update" または "delete"
  
  // 変更前の値（JSON形式で保存）
  oldValues         Json?     // {wakeUpTime, departureTime, clockIn, clockOut, breakMinutes, clockInLocation, clockOutLocation}
  
  // 変更後の値（JSON形式で保存、deleteの場合はnull）
  newValues         Json?     // {wakeUpTime, departureTime, clockIn, clockOut, breakMinutes, clockInLocation, clockOutLocation}
  
  // 変更されたフィールドのリスト
  changedFields     String[]  // ["wakeUpTime", "clockIn", ...]
  
  reason            String?   // 修正理由
  createdAt         DateTime  @default(now())

  attendance        Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  company           Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  modifier          Employee   @relation("Modifier", fields: [modifiedBy], references: [id], onDelete: Cascade)

  @@index([attendanceId])
  @@index([companyId])
  @@index([employeeId])
  @@index([createdAt])
  @@map("attendance_modification_logs")
}

// 営業先訪問テーブル
model SalesVisit {
  id              Int       @id @default(autoincrement())
  companyId       Int
  employeeId      Int
  date            DateTime  @db.Date // 訪問日
  companyName     String    // 営業先の会社名
  contactPersonName String? // 取引先担当者名
  purpose         String    // 目的: "商談", "見積", "アフターサービス", "その他"
  entryTime       DateTime? @db.Time // 入店時刻
  exitTime        DateTime? @db.Time // 退店時刻
  entryLocation   Json?     // 入店時の位置情報 {latitude, longitude, accuracy}
  exitLocation    Json?     // 退店時の位置情報 {latitude, longitude, accuracy}
  meetingNotes    String?   @db.Text // 商談内容メモ（最大1000文字）
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee        Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([employeeId])
  @@index([date])
  @@map("sales_visits")
}

// 請求先企業マスタ
model BillingClient {
  id              Int       @id @default(autoincrement())
  companyId       Int       // 請求元企業（aimsなど）
  name            String    // 請求先企業名
  code            String?   // 請求先企業コード
  address         String?   // 住所
  phone           String?   // 電話番号
  fax             String?   // FAX番号
  contactPerson   String?   // 担当者名
  bankName        String?   // 銀行名
  bankBranch      String?   // 支店名
  accountNumber   String?   // 口座番号
  accountHolder   String?   // 口座名義
  taxRate         Float     @default(0.1) // 消費税率（10% = 0.1）
  invoiceNumberPrefix String? // 請求書番号プレフィックス
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees       Employee[]
  invoices        Invoice[]
  
  @@map("billing_clients")
}

// 請求書
model Invoice {
  id              Int       @id @default(autoincrement())
  companyId       Int       // 請求元企業
  billingClientId Int       // 請求先企業
  invoiceNumber   String    @unique // 請求書番号
  subject         String    // 件名
  periodStart     DateTime  @db.Date // 請求期間開始
  periodEnd       DateTime  @db.Date // 請求期間終了
  paymentTerms    String    // 代金決済条件
  dueDate         DateTime  @db.Date // お支払い期日
  subtotal        Int       // 小計（税抜）
  taxAmount       Int       // 消費税額
  totalAmount     Int       // 合計金額（税込）
  transportationCost Int?   @default(0) // 交通費
  adjustmentAmount Int?     @default(0) // 調整金額
  billingClientName String? // 請求先企業名（編集可能、便宜上名前を変える場合に使用）
  status          String    @default("draft") // draft, issued, billed, paid
  issuedAt        DateTime? // 発行日
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  billingClient   BillingClient @relation(fields: [billingClientId], references: [id], onDelete: Cascade)
  details         InvoiceDetail[]
  
  @@index([companyId])
  @@index([billingClientId])
  @@index([periodStart])
  @@index([periodEnd])
  @@map("invoices")
}

// 請求明細
model InvoiceDetail {
  id              Int       @id @default(autoincrement())
  invoiceId       Int
  employeeId      Int?      // 従業員ID（手動追加の費目項目の場合はnull）
  itemName        String?   // 費目名（手動追加の費目項目の場合に使用）
  workDays        Int       // 勤務日数
  basicRate       Int       // 基本単価
  basicAmount     Int       // 基本金額
  overtimeHours   Float?    @default(0) // 残業時間
  overtimeRate    Float?    // 残業単価
  overtimeAmount  Int?      @default(0) // 残業金額
  absenceDays     Int?      @default(0) // 欠勤日数
  absenceDeduction Int?     @default(0) // 欠勤減算額
  lateEarlyDeduction Int?   @default(0) // 遅刻・早退減算額
  subtotal        Int       // 小計
  notes           String?   // 備考（減算が発生した日付など）
  
  invoice         Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  employee        Employee? @relation(fields: [employeeId], references: [id])
  
  @@index([invoiceId])
  @@index([employeeId])
  @@map("invoice_details")
}
