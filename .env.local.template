# AI Kitchen Partner 環境変数テンプレート
# このファイルをコピーして .env.local を作成し、実際の値を設定してください

# ============================================
# Supabase Configuration
# ============================================
# Supabaseダッシュボード → Settings → API から取得
# Project URL: https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here

# anon public key: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ============================================
# OpenAI API Key
# ============================================
# https://platform.openai.com/api-keys から取得
# sk-... で始まる文字列
OPENAI_API_KEY=your_openai_api_key_here

# ============================================
# Database URL (Optional - Supabase使用時)
# ============================================
# Supabaseダッシュボード → Settings → Database → Connection string
# [YOUR-PASSWORD] を実際のパスワードに置き換え
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxx.supabase.co:5432/postgres
